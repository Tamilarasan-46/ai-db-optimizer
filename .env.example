# ============================================================================
# AI Database Optimizer — configuration
# ----------------------------------------------------------------------------
# Setup:   cp .env.example .env     (this file works AS-IS for the local demo)
# Then:    docker compose up --build
#
# Everything below has a sensible default. You only ever NEED to touch the
# TARGET section (to analyse your own database) — and even that can be done
# from the UI instead ("+ Connect database…" in the header).
# ============================================================================

# ── Which database should the optimizer ANALYSE? ────────────────────────────
# Leave EMPTY  -> demo mode: analyses the bundled demo database (zero config).
# Set a URL    -> your PostgreSQL, connected READ-ONLY (enforced server-side).
#
# From inside Docker, "host.docker.internal" = the machine running Docker.
# Create the read-only user first — one command, see README "Prepare your
# database" (uses setup-target-readonly-user.sql).
#
# TARGET_DATABASE_URL=postgresql://ai_opt_readonly:YOUR_RO_PASSWORD@host.docker.internal:5432/your_database
TARGET_DATABASE_URL=

# EXPLAIN mode for query analysis on the target:
#   false = EXPLAIN only (estimates, never executes your queries — safe default)
#   true  = EXPLAIN ANALYZE (executes; accurate timings; use on non-prod only)
EXPLAIN_ANALYZE=false

# ── Optimizer's own storage (runs in the bundled container) ─────────────────
# Used for findings, insights, embeddings AND the demo dataset. Change the
# passwords if you expose anything beyond localhost.
AI_OPTIMIZER_USER=ai_optimizer_user
AI_OPTIMIZER_PASSWORD=optimizer_app_pw
AI_OPTIMIZER_DB=ai_optimizer_db
POSTGRES_SUPERUSER_USER=postgres
POSTGRES_SUPERUSER_PASSWORD=optimizer_local_pw

# Internal connection string for backend + ai-service (service name "postgres"
# = the bundled container; only change if you renamed things above).
DATABASE_URL=postgresql://ai_optimizer_user:optimizer_app_pw@postgres:5432/ai_optimizer_db

# ── Service wiring & ports (defaults are fine) ──────────────────────────────
AI_SERVICE_URL=http://ai-service:5000
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Host ports (change on conflicts) and bind address.
# BIND_ADDR=127.0.0.1 keeps everything local-only; 0.0.0.0 exposes on your LAN
# (set real passwords first — there is NO authentication built in).
BIND_ADDR=127.0.0.1
FRONTEND_PORT=8080
BACKEND_PORT=8000
AI_SERVICE_PORT=5000
STORAGE_DB_PORT=5433

# Postgres image tag for the bundled storage container (pgvector/pgvector:*).
PG_IMAGE_TAG=pg16
