# ============================================================================
# Production env for docker-compose.prod.yml  →  copy to .env and edit.
#   cp .env.prod.example .env
# NEVER commit the real .env (already gitignored).
# ============================================================================

# --- Site address (controls HTTP vs HTTPS) ----------------------------------
# BLANK  -> plain HTTP on :80  (local test, or reach the VM at http://SERVER_IP)
# FREE HTTPS (no domain purchase): build an sslip.io host from the server's public
#   IP, dashes for dots. IP 152.67.10.20 -> SITE_ADDRESS=152-67-10-20.sslip.io
#   (Caddy auto-fetches a real Let's Encrypt cert once the IP is reachable).
# HAVE A DOMAIN: SITE_ADDRESS=optimizer.example.com and point its A record here.
SITE_ADDRESS=

# CORS allowlist. "*" is fine here because the UI and /api are same-origin (both
# behind Caddy). If you set SITE_ADDRESS to a host, set this to https://<that-host>.
ALLOWED_ORIGINS=*

# --- Public hardening (backend also forces this via compose) ----------------
# true  = public demo: analyses only the bundled demo DB, /target/connect off
PUBLIC_DEMO=true

# --- Optimizer's own storage (internal DB — pick strong passwords) ----------
POSTGRES_SUPERUSER_USER=postgres
POSTGRES_SUPERUSER_PASSWORD=CHANGE_ME_strong_password
AI_OPTIMIZER_DB=ai_optimizer_db
AI_OPTIMIZER_USER=ai_optimizer_user
AI_OPTIMIZER_PASSWORD=CHANGE_ME_another_password

# Backend connects to its own storage over the internal docker network:
DATABASE_URL=postgresql://ai_optimizer_user:CHANGE_ME_another_password@postgres:5432/ai_optimizer_db

# Leave TARGET_DATABASE_URL empty on a public demo (PUBLIC_DEMO ignores it anyway).
TARGET_DATABASE_URL=

# Internal service URL (docker network name) — do not change for compose.
AI_SERVICE_URL=http://ai-service:5000

# EXPLAIN only (safe) unless you deliberately want EXPLAIN ANALYZE execution.
EXPLAIN_ANALYZE=false

# Embedding model for the local RAG (downloaded on first ai-service boot).
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Postgres major version. PINNED — the data volume is tied to it: a volume made
# by one major version can't be opened by another (Postgres aborts with "database
# files are incompatible"). Don't change this on an existing deployment without
# migrating (pg_dump/restore) or wiping the prod volume first:
#   docker compose -f docker-compose.prod.yml down
#   docker volume rm ai-db-optimizer_pgdata_ai_optimizer_prod
PG_IMAGE_TAG=pg16
